# Local development
VITE_API_BASE_URL=http://localhost:5000/api

# Production — Vercel → Settings → Environment Variables
# Frontend live: https://restaurant-frontend-blush.vercel.app
# Replace with your Railway API domain + /api:
# VITE_API_BASE_URL=https://new-jubba-api-production.up.railway.app/api

# Direct browser upload fallback (optional — backend upload is preferred)
# Create an UNSIGNED upload preset in Cloudinary dashboard named "new_jubba_menu"
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=new_jubba_menu
VITE_STATIC_FORMS_API_KEY=your_static_forms_api_key
